# Configuration du serveur
NODE_ENV=development
PORT=3000
HOST=0.0.0.0
CORS_ORIGIN=http://localhost:5173

# Configuration de la base de données
DB_CLIENT=postgresql
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_DATABASE=sgpc_db
DB_SSL=false

# Configuration de l'authentification
JWT_SECRET=votre_jwt_secret_tres_long_et_securise
JWT_EXPIRES_IN=1d
REFRESH_TOKEN_SECRET=votre_refresh_token_secret_tres_long_et_securise
REFRESH_TOKEN_EXPIRES_IN=7d

# Configuration des e-mails (optionnel)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=user@example.com
SMTP_PASS=your-email-password
SMTP_FROM=noreply@example.com

# Configuration du stockage (optionnel)
STORAGE_PROVIDER=local
STORAGE_PATH=./uploads

# Configuration du logging
LOG_LEVEL=debug
LOG_TO_FILE=true
LOG_FILE_PATH=logs/app.log

# Configuration du taux limite (rate limiting)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
