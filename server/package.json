{
    "name": "server",
    "version": "1.0.0",
    "description": "API server for the application",
    "main": "index.js",
    "type": "module",
    "scripts": {
        "dev": "tsx watch index.ts",
        "build": "tsc && node -e \"const fs=require('fs');const path=require('path');function copyJs(src,dest){fs.readdirSync(src,{withFileTypes:true}).forEach(e=>{const s=path.join(src,e.name),d=path.join(dest,e.name);if(e.isDirectory()&&e.name!=='node_modules'&&e.name!=='dist'){copyJs(s,d)}else if(e.name.endsWith('.js')&&!fs.existsSync(d)){fs.mkdirSync(path.dirname(d),{recursive:true});fs.copyFileSync(s,d)}})}copyJs('.',path.join('..','dist','server'))\"",
        "start": "node dist/index.js",
        "test": "jest",
        "init-species": "node scripts/init-taxe-especes.js"
    },
    "dependencies": {
        "@types/multer": "^2.0.0",
        "@types/shapefile": "^0.6.4",
        "bcryptjs": "^3.0.2",
        "cors": "^2.8.5",
        "dotenv": "^16.3.1",
        "express": "^4.18.2",
        "express-rate-limit": "^7.1.3",
        "jsonwebtoken": "^9.0.2",
        "multer": "^2.0.2",
        "pg": "^8.11.3",
        "shapefile": "^0.6.6",
        "wkx": "^0.5.0"
    },
    "devDependencies": {
        "@types/cors": "^2.8.17",
        "@types/express": "^4.17.21",
        "@types/jsonwebtoken": "^9.0.5",
        "jest": "^29.7.0",
        "ts-jest": "^29.1.1",
        "tsx": "^4.7.0",
        "typescript": "~5.8.3"
    }
}
