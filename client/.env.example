# Configuration de l'API
VITE_API_BASE_URL=http://localhost:3000/api

# Configuration de l'authentification
VITE_AUTH_TOKEN_KEY=auth_token
VITE_REFRESH_TOKEN_KEY=refresh_token
VITE_TOKEN_EXPIRY_KEY=token_expiry

# Configuration de l'application
VITE_APP_NAME="Système de Gestion des Permis de Chasse"
VITE_APP_VERSION=1.0.0
VITE_APP_ENV=development

# Configuration de la carte (Mapbox, Google Maps, etc.)
VITE_MAP_PROVIDER=mapbox
VITE_MAPBOX_ACCESS_TOKEN=votre_cle_mapbox
VITE_GOOGLE_MAPS_API_KEY=votre_cle_google_maps

# Configuration des fonctionnalités expérimentales
VITE_ENABLE_EXPERIMENTAL_FEATURES=false
