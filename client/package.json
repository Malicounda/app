  "type": "commonjs",
  "main": "index.html",
  "scripts": {
    "dev": "vite",
    "build": "cross-env NODE_OPTIONS=--max-old-space-size=4096 tsc && vite build --config vite.simple.config.ts",
    "preview": "vite preview",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "tauri:build:debug": "tauri build --debug",
    "type-check": "cross-env NODE_OPTIONS=--max-old-space-size=4096 tsc --noEmit",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "optimize-images": "node scripts/optimize-images.js",
    "optimize-images:watch": "nodemon --watch public --ext jpg,jpeg,png,webp --exec \"npm run optimize-images\"",
    "test:compatibility": "node scripts/test-compatibility.js",
    "test:compatibility:ci": "node scripts/test-compatibility.js http://localhost:5173",
    "test:lighthouse": "lighthouse http://localhost:5173 --output html --output-path ./test-results/lighthouse-report.html --chrome-flags=\"--headless\""
